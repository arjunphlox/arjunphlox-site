---
import Hero from '../components/Hero.astro';
import CompetencyGrid from '../components/CompetencyGrid.astro';
import Bio from '../components/Bio.astro';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width" />
  <title>Arjun Phlox</title>
  <style is:global>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#111;color:#fff}
    a{color:inherit;text-decoration:none}
    .page-grid{display:grid;grid-template-columns:repeat(6,1fr);min-height:100vh}
    .cell{border-right:1px solid #2a2a2a;border-bottom:1px solid #2a2a2a;padding:24px;position:relative}
    /* Row 1 */
    .hero-name-cell{grid-column:1;grid-row:1}
    .hero-name{font-size:2.6rem;font-weight:800;line-height:1;letter-spacing:-0.03em;color:#fff}
    .hero-roles{display:flex;flex-wrap:wrap;gap:6px;margin-top:12px;font-size:0.72rem;color:#666;letter-spacing:0.04em;align-items:center}
    .hero-role-sep{opacity:0.3;font-size:0.6rem}
    .hero-socials{display:flex;gap:10px;margin-top:auto;padding-top:40px}
    .social-link{width:30px;height:30px;border:1px solid #333;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.65rem;color:#888;transition:all 0.2s}
    .social-link:hover{background:#fff;color:#111;border-color:#fff}
    .hero-logos-cell{grid-column:2/5;grid-row:1;display:flex;flex-direction:column;justify-content:space-between}
    .brand-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;align-items:center}
    .brand-item{font-size:0.8rem;font-weight:600;color:#444;text-align:center;letter-spacing:0.05em;text-transform:uppercase}
    .hero-stats{display:flex;gap:12px;margin-top:auto;padding-top:16px;font-size:0.72rem;color:#888;align-items:center}
    .hero-stat-sep{opacity:0.4}
    .hero-up-arrow{grid-column:5;grid-row:1;display:flex;align-items:center;justify-content:center;font-size:2rem;color:#333}
    /* Row 2 */
    .photo-cell{grid-column:1;grid-row:2;display:flex;align-items:stretch;background:#1a1a1a;min-height:300px;padding:0;overflow:hidden}
    .photo-cell img{width:100%;height:100%;object-fit:cover;filter:grayscale(100%)}
    .bio-text-cell{grid-column:2/5;grid-row:2;display:flex;flex-direction:column;justify-content:space-between;padding:32px 24px}
    .hero-tabs{display:flex;gap:4px;margin-bottom:20px}
    .hero-tab{width:50px;height:2px;background:#333}
    .hero-tab.active{background:#fff}
    .bio-text{font-style:italic;font-size:1.1rem;line-height:1.8;color:#ccc}
    .hero-nav{display:flex;gap:8px;margin-top:32px}
    .nav-pill{padding:8px 16px;border:1px solid #333;border-radius:20px;font-size:0.72rem;font-weight:700;letter-spacing:0.1em;color:#888}
    .nav-pill:hover{background:#fff;color:#111;border-color:#fff}
    .bio-up-arrow{grid-column:5;grid-row:2;display:flex;align-items:center;justify-content:center;font-size:2rem;color:#333}
    /* Competency - spans both rows */
    .competency-cell{grid-column:6;grid-row:1/3;display:flex;flex-direction:column;justify-content:space-between;padding:24px;align-items:flex-end}
    .skills-list{display:flex;flex-wrap:wrap;gap:4px;justify-content:flex-end}
    .hobby-list{display:flex;flex-wrap:wrap;gap:4px;justify-content:flex-end;margin-top:8px}
    .skill-item{font-size:0.72rem;color:#555;white-space:nowrap}
    .skill-sep{color:#2a2a2a;font-size:0.72rem}
    .competency-divider{width:100%;height:1px;background:#2a2a2a;margin:16px 0}
    .competency-footer{display:flex;justify-content:space-between;align-items:center;width:100%;font-size:0.72rem;color:#555}
    .competency-links a{color:#666;margin-left:8px;font-size:0.72rem;font-weight:600;letter-spacing:0.06em}
    .competency-links a:hover,.competency-links a.active{color:#fff}
  </style>
</head>
<body>
  <div class="page-grid">
    <Hero />
    <CompetencyGrid />
    <Bio />
  </div>
</body>
</html>
